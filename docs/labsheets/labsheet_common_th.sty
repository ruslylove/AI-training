% Thai variant of labsheet_common.sty -- shared style for the Thai-language
% AI-training student labsheets. Same layout/boxes/diagram styles as
% labsheet_common.sty, but built for XeLaTeX with a bundled Thai font
% (Sarabun, SIL OFL licensed, see fonts/OFL.txt) instead of pdflatex's
% Latin-only fontenc/inputenc setup.
% Build with: xelatex <file>.tex  (NOT pdflatex -- Thai glyphs need XeTeX/fontspec)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{labsheet_common_th}

\RequirePackage[margin=2.5cm]{geometry}
\RequirePackage{fontspec}
\RequirePackage{xcolor}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins,breakable}
\RequirePackage{enumitem}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{listings}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage[colorlinks=true,linkcolor=labblue,urlcolor=labblue,citecolor=labblue]{hyperref}
\RequirePackage{parskip}
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta,positioning}
\RequirePackage{graphicx} % for \resizebox around diagrams

% ---- Thai font (bundled, so building doesn't depend on the host system
% having a Thai font installed) + ICU-based line breaking so long Thai text
% (no spaces between words) wraps at proper word boundaries ----
\setmainfont{Sarabun}[
  Path = fonts/,
  Extension = .ttf,
  UprightFont = *-Regular,
  BoldFont = *-Bold,
  ItalicFont = *-Italic,
  BoldItalicFont = *-BoldItalic,
]
\XeTeXlinebreaklocale "th_TH"
\XeTeXlinebreakskip = 0pt plus 1pt minus 0.1pt
% Thai word segments (from ICU line breaking above) are atomic -- TeX can't
% hyphenate mid-word -- so give the line breaker extra stretch/shrink room
% to avoid overfull lines when a segment barely doesn't fit.
\tolerance=1500
\emergencystretch=2.5em
% code/settings blocks stay in Latin Modern Mono (bundled with any TeX Live/
% MacTeX install) since their content -- filenames, commands, YAML -- is
% deliberately left untranslated.

% ---- palette (identical to labsheet_common.sty) ----
\definecolor{labblue}{HTML}{1F5FA8}
\definecolor{labbluebg}{HTML}{EAF1FB}
\definecolor{labgreen}{HTML}{2E7D32}
\definecolor{labgreenbg}{HTML}{EAF6EC}
\definecolor{laborange}{HTML}{B54708}
\definecolor{laborangebg}{HTML}{FDF1E7}
\definecolor{labgray}{HTML}{4B5563}
\definecolor{labgraybg}{HTML}{F3F4F6}
\definecolor{labbannerbg}{HTML}{16324F}

% ---- headings ----
\titleformat{\section}{\normalfont\Large\bfseries\color{labbannerbg}}{\thesection}{0.6em}{}
\titleformat{\subsection}{\normalfont\large\bfseries\color{labblue}}{\thesubsection}{0.6em}{}
\titlespacing*{\section}{0pt}{1.4em}{0.7em}
\titlespacing*{\subsection}{0pt}{1.1em}{0.5em}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\small\color{labgray}\thepage}

% ---- code / settings block style ----
\lstdefinestyle{labcode}{
  basicstyle=\ttfamily\small,
  backgroundcolor=\color{labgraybg},
  frame=single,
  rulecolor=\color{labgray!40},
  framesep=6pt,
  xleftmargin=6pt,
  xrightmargin=6pt,
  breaklines=true,
  showstringspaces=false,
  columns=fullflexible,
}
\lstset{style=labcode}

% ---- callout boxes (titles translated per-lab via optional arg) ----
\newtcolorbox{tipbox}[1][เคล็ดลับ]{
  enhanced, breakable, colback=labgreenbg, colframe=labgreen,
  boxrule=0.6pt, arc=2pt, left=8pt, right=8pt, top=5pt, bottom=5pt,
  title={\textbf{#1}}, fonttitle=\bfseries\color{white},
  colbacktitle=labgreen, coltitle=white,
}
\newtcolorbox{notebox}[1][ประเด็นสำคัญ]{
  enhanced, breakable, colback=labbluebg, colframe=labblue,
  boxrule=0.6pt, arc=2pt, left=8pt, right=8pt, top=5pt, bottom=5pt,
  title={\textbf{#1}}, fonttitle=\bfseries\color{white},
  colbacktitle=labblue, coltitle=white,
}
\newtcolorbox{warnbox}[1][แก้ปัญหาเบื้องต้น]{
  enhanced, breakable, colback=laborangebg, colframe=laborange,
  boxrule=0.6pt, arc=2pt, left=8pt, right=8pt, top=5pt, bottom=5pt,
  title={\textbf{#1}}, fonttitle=\bfseries\color{white},
  colbacktitle=laborange, coltitle=white,
}

% ---- title banner ----
% \labtitle{Lab number/label}{Title}{Subtitle}
\newcommand{\labtitle}[3]{%
  \begin{tcolorbox}[
      enhanced, colback=labbannerbg, colframe=labbannerbg,
      arc=3pt, boxrule=0pt, left=14pt, right=14pt, top=12pt, bottom=12pt,
      width=\textwidth,
    ]
    {\color{white}\large\textbf{#1}}\\[3pt]
    {\color{white}\Huge\textbf{#2}}\\[5pt]
    {\color{white!85!black}\large #3}
  \end{tcolorbox}
  \vspace{4mm}
}

\newcommand{\nocodebadge}{%
  \begin{center}
  \colorbox{labgreenbg}{\textcolor{labgreen}{\textbf{ไม่ต้องมีพื้นฐานการเขียนโปรแกรม}}}
  \end{center}
  \vspace{2mm}
}

\setlist[itemize]{leftmargin=1.4em, itemsep=2pt, topsep=2pt}
\setlist[enumerate]{leftmargin=1.6em, itemsep=4pt, topsep=2pt}

% ---- block diagram node/arrow styles ----
% autobox   = a step already done for you (script runs automatically)
% actionbox = a step YOU do (labeling / editing a setting)
% scorebox  = the score you get out at the end
\tikzset{
  autobox/.style={draw=labgray, thick, rounded corners, fill=labgraybg,
    minimum height=1.2cm, minimum width=2.5cm, text width=2.3cm,
    align=center, font=\footnotesize},
  actionbox/.style={draw=laborange, thick, rounded corners, fill=laborangebg,
    minimum height=1.2cm, minimum width=2.5cm, text width=2.3cm,
    align=center, font=\footnotesize\bfseries},
  scorebox/.style={draw=labblue, thick, rounded corners, fill=labbluebg,
    minimum height=1.2cm, minimum width=2.5cm, text width=2.3cm,
    align=center, font=\footnotesize\bfseries},
  flowarrow/.style={-{Latex[length=2.6mm]}, thick, draw=labgray},
  loopA/.style={-{Latex[length=2.6mm]}, thick, draw=laborange},
  loopB/.style={-{Latex[length=2.6mm]}, thick, draw=labblue, dashed},
  looplabel/.style={font=\footnotesize\itshape, align=center, text width=3.3cm},
}

\newcommand{\diagramlegend}{%
  \begin{center}
  \begin{tikzpicture}
    \node[autobox, minimum height=0.55cm, minimum width=1.9cm, text width=1.7cm] (l1) {ทำไว้ให้แล้ว};
    \node[actionbox, right=4mm of l1, minimum height=0.55cm, minimum width=1.9cm, text width=1.7cm] (l2) {ขั้นตอนที่คุณทำ};
    \node[scorebox, right=4mm of l2, minimum height=0.55cm, minimum width=1.9cm, text width=1.7cm] (l3) {คะแนนของคุณ};
  \end{tikzpicture}
  \end{center}
}

\endinput
